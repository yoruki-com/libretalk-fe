{
  "expo": {
    "name": "libre-talk",
    "slug": "libre-talk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-without-stroke.png",
    "scheme": "libretalk",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.libretalk.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo-without-stroke.png",
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true,
      "package": "com.libretalk.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo-without-stroke.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-without-stroke.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow LibreTalk to access your photos to set your profile picture.",
          "cameraPermission": "Allow LibreTalk to take photos to set your profile picture."
        }
      ],
      [
        "with-rn-image-crop-picker",
        {
          "photosPermission": "Allow LibreTalk to access your photos to set your profile picture.",
          "cameraPermission": "Allow LibreTalk to take photos to set your profile picture."
        }
      ],
      "@rnmapbox/maps"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
