{
  "expo": {
    "name": "libretalk",
    "slug": "libretalk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-without-stroke.png",
    "scheme": "libretalk",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.libretalk.app"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo-without-stroke.png",
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true,
      "package": "com.libretalk.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo-without-stroke.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-without-stroke.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow LibreTalk to access your photos to set your profile picture.",
          "cameraPermission": "Allow LibreTalk to take photos to set your profile picture."
        }
      ],
      [
        "with-rn-image-crop-picker",
        {
          "photosPermission": "Allow LibreTalk to access your photos to set your profile picture.",
          "cameraPermission": "Allow LibreTalk to take photos to set your profile picture."
        }
      ],
      "@rnmapbox/maps",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo-without-stroke.png",
          "color": "#E6F4FE"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b650eaa5-a5a3-44ac-85ff-5ae7f20ef681"
      }
    }
  }
}
